{
  "$schema": "https://raw.githubusercontent.com/electron-userland/electron-builder/master/packages/app-builder-lib/scheme.json",
  "appId": "com.frontend.deploy.manager",
  "productName": "Frontend Deploy Manager",
  "directories": {
    "output": "release"
  },
  "npmRebuild": false,
  "publish": null,
  "files": [
    "dist/**/*",
    "dist-electron/**/*",
    "doc/**/*"
  ],
  "extraResources": [
    {
      "from": "doc",
      "to": "doc"
    }
  ],
  "win": {
    "icon": "build/icon.ico",
    "target": [
      {
        "target": "nsis",
        "arch": ["x64"]
      }
    ],
    "sign": null
  },
  "nsis": {
    "oneClick": false,
    "allowToChangeInstallationDirectory": true,
    "installerLanguages": ["zh_CN"],
    "language": 2052,
    "shortcutName": "Frontend Deploy Manager"
  },
  "mac": {
    "target": [
      {
        "target": "dmg",
        "arch": ["x64", "arm64"]
      }
    ],
    "identity": null,
    "hardenedRuntime": false,
    "gatekeeperAssess": false,
    "entitlements": null,
    "entitlementsInherit": null
  },
  "dmg": {
    "sign": false,
    "contents": [
      {
        "x": 410,
        "y": 150,
        "type": "link",
        "path": "/Applications"
      },
      {
        "x": 130,
        "y": 150,
        "type": "file"
      }
    ]
  },
  "linux": {
    "target": ["AppImage"]
  }
}
